  endif
  if settings.deco_image_18 != blank
    assign img_url = settings.deco_image_18 | image_url: width: 200
    assign all_decos = all_decos | append: img_url | append: '|||'
  endif

  assign deco_array = all_decos | split: '|||'
  assign deco_count = deco_array.size
-%}

{%- if deco_count > 0 -%}
<div class="collage-decorations" aria-hidden="true">
  {%- for deco in deco_array -%}
    {%- if deco != blank -%}
      <div class="global-deco" data-deco-item>
        <img src="{{ deco }}" alt="" loading="lazy">
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  (function() {
    const container = document.querySelector('.collage-decorations');
    if (!container) return;

    const items = [...container.querySelectorAll('[data-deco-item]')];
    if (items.length === 0) return;

    // Depth cycle — distributes items across far/mid/near
    const depthCycle = ['far', 'mid', 'near'];

    items.forEach((item, i) => {
      // Random position across the full viewport
      item.style.top = (Math.random() * 90) + '%';
      item.style.left = (Math.random() * 90) + '%';

      // Random rotation for chaos
      const rotation = Math.floor(Math.random() * 60) - 30;
      item.style.setProperty('--deco-rotation', rotation + 'deg');

      // Random animation delay so they don't all sync up
      item.style.animationDelay = (Math.random() * 6).toFixed(1) + 's';

      // Assign depth layer cycling through far → mid → near
      item.classList.add('global-deco--' + depthCycle[i % 3]);
      item.classList.add('is-visible');
    });
  })();
</script>
{%- endif -%}
