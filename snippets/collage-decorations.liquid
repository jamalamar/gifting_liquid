    assign img_url = settings.deco_image_10 | image_url: width: 200
    assign all_decos = all_decos | append: img_url | append: '|||'
  endif
  if settings.deco_image_11 != blank
    assign img_url = settings.deco_image_11 | image_url: width: 200
