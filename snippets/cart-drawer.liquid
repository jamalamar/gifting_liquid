{%- comment -%}
  Cart drawer / mini cart - Clean style
{%- endcomment -%}

{%- comment -%} Box products data - placed outside drawer body so it persists during JS re-renders {%- endcomment -%}
{%- assign box_collection = collections['cajas-de-regalo'] -%}
{%- if box_collection.products.size > 0 -%}
  <script type="application/json" data-box-products>
    [
      {%- for product in box_collection.products -%}
        {%- if product.tags contains 'is-gift-box' -%}
          {
            "id": {{ product.id }},
            "variantId": {{ product.selected_or_first_available_variant.id }},
            "title": {{ product.title | json }},
            "image": {{ product.featured_media | image_url: width: 100 | json }},
            "handle": {{ product.handle | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>
{%- endif -%}

<div class="cart-drawer" data-cart-drawer data-free-shipping-threshold="{{ settings.free_shipping_threshold | default: 0 }}" aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-drawer-close></div>

  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        {% render 'icon-cart' %}
        <span>Tu Carrito</span>
        <span class="cart-drawer__count" data-drawer-cart-count>{{ cart.item_count }}</span>
      </h2>
      <button type="button" class="cart-drawer__close" data-cart-drawer-close aria-label="Cerrar carrito">
        {% render 'icon-close' %}
      </button>
    </div>

    <div class="cart-drawer__body" data-cart-drawer-body>
      {%- if cart.item_count > 0 -%}
        {%- comment -%} Gift Box Selector {%- endcomment -%}
        {% render 'cart-box-selector' %}

        <div class="cart-drawer__items">
          {%- for item in cart.items -%}
            {%- assign is_gift_box = false -%}
            {%- if item.product.tags contains 'is-gift-box' -%}
              {%- assign is_gift_box = true -%}
            {%- endif -%}

            <div class="cart-drawer__item{% if is_gift_box %} cart-drawer__item--box-product{% endif %}" data-cart-drawer-item data-key="{{ item.key }}"{% if is_gift_box %} data-is-box-product{% endif %}>
              <div class="cart-drawer__item-image">
                {%- if item.image -%}
                  <a href="{{ item.url }}">
                    <img
                      src="{{ item.image | image_url: width: 150 }}"
                      alt="{{ item.title }}"
                      width="70"
                      height="70"
                      loading="lazy"
                    >
                  </a>
                {%- else -%}
                  <div class="cart-drawer__item-placeholder">
                    {% render 'icon-gift' %}
                  </div>
                {%- endif -%}
              </div>

              <div class="cart-drawer__item-info">
                <h3 class="cart-drawer__item-title">
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                </h3>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}

                {%- unless is_gift_box -%}
                  <div class="cart-drawer__qty-group">
                    <button type="button" class="cart-drawer__qty-btn" data-drawer-qty-minus data-key="{{ item.key }}" aria-label="Disminuir cantidad">
                      <span>−</span>
                    </button>
                    <span class="cart-drawer__qty-value" data-drawer-qty-value>{{ item.quantity }}</span>
                    <button type="button" class="cart-drawer__qty-btn" data-drawer-qty-plus data-key="{{ item.key }}" aria-label="Aumentar cantidad">
                      <span>+</span>
                    </button>
                  </div>

                  {%- comment -%} Box Assignment Dropdown {%- endcomment -%}
                  <div class="cart-drawer__item-box-assign">
                    {% render 'cart-item-box-dropdown', item: item %}
                  </div>
                {%- endunless -%}
              </div>

              {%- unless is_gift_box -%}
                <div class="cart-drawer__item-price">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <span class="cart-drawer__item-price-compare">{{ item.original_line_price | money }}</span>
                  {%- endif -%}
                  <span class="cart-drawer__item-price-current">{{ item.final_line_price | money }}</span>
                </div>

                <button type="button" class="cart-drawer__item-remove" data-drawer-remove-item data-key="{{ item.key }}" aria-label="Eliminar {{ item.product.title }}">
                  {% render 'icon-close' %}
                </button>
              {%- endunless -%}
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="cart-drawer__empty">
          <div class="cart-drawer__empty-icon">
            {% render 'icon-cart' %}
          </div>
          <p class="cart-drawer__empty-title">Tu carrito esta vacio</p>
          <p class="cart-drawer__empty-text">Explora nuestros productos y encuentra el regalo perfecto.</p>
          <a href="/collections/catalogo" class="btn btn--secondary cart-drawer__empty-btn" data-cart-drawer-close>
            Ver productos
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        {%- assign free_shipping_threshold = settings.free_shipping_threshold | plus: 0 -%}
        {%- if free_shipping_threshold > 0 -%}
          <div class="cart-drawer__shipping">
            {%- assign threshold = free_shipping_threshold | times: 100 -%}
            {%- assign remaining = threshold | minus: cart.total_price -%}
            {%- assign progress = cart.total_price | times: 100.0 | divided_by: threshold -%}
            {%- if progress > 100 -%}{%- assign progress = 100 -%}{%- endif -%}

            {%- if remaining > 0 -%}
              <p class="cart-drawer__shipping-text">
                {% render 'icon-truck' %}
                <span>Te faltan <strong>{{ remaining | money }}</strong> para envio gratis</span>
              </p>
            {%- else -%}
              <p class="cart-drawer__shipping-text cart-drawer__shipping-text--free">
                {% render 'icon-check' %}
                <span>Tienes envio gratis</span>
              </p>
            {%- endif -%}

            <div class="cart-drawer__shipping-bar">
              <div class="cart-drawer__shipping-progress" style="width: {{ progress }}%"></div>
            </div>
          </div>
        {%- endif -%}

        <div class="cart-drawer__subtotal">
          <span>Subtotal</span>
          <span data-drawer-subtotal>{{ cart.total_price | money }}</span>
        </div>

        <a href="{{ routes.cart_url }}" class="btn btn--primary cart-drawer__continue-to-cart">
          Continuar al carrito
          {% render 'icon-arrow-right' %}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>
