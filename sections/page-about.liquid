<section class="page-about collage-section" data-section-id="{{ section.id }}" data-animate="stagger">

  <!-- Block 1: Introducción — Hero-style 2-column -->
  <div class="about-intro">
    <div class="container">
      <div class="about-intro__grid">
        <div class="about-intro__text-col">
          <div class="sticker-badge animate-item" style="--i:0">
            {% render 'icon-sparkle' %}
            <span>Nosotros</span>
          </div>
          <h1 class="about-intro__title animate-item" style="--i:1">
            {{ section.settings.intro_title }}
          </h1>
          <div class="about-intro__text animate-item" style="--i:2">
            {{ section.settings.intro_text }}
          </div>
        </div>
        <div class="about-intro__visual animate-item" style="--i:3">
          {%- if section.settings.sticker_1 != blank -%}
            <div class="about-polaroid about-polaroid--right">
              <div class="about-polaroid__frame">
                <img src="{{ section.settings.sticker_1 | image_url: width: 500 }}" alt="" loading="lazy">
                {%- if section.settings.intro_caption != blank -%}
                  <span class="about-polaroid__caption">{{ section.settings.intro_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <!-- Block 2: Qué es Gifting — Accent background + paper card -->
  <div class="about-what">
    <div class="container">
      <div class="about-what__layout">
        <div class="about-what__card animate-item" style="--i:0">
          <h2 class="about-what__title">
            {{ section.settings.what_title }}
          </h2>
          <div class="about-what__text">
            {{ section.settings.what_text }}
          </div>
          {%- if section.settings.sticker_2 != blank -%}
            <div class="about-what__deco about-sticker">
              <img src="{{ section.settings.sticker_2 | image_url: width: 150 }}" alt="Decoration" loading="lazy">
            </div>
          {%- endif -%}
        </div>
        {%- if section.settings.what_polaroid != blank -%}
          <div class="about-what__polaroid animate-item" style="--i:1">
            <div class="about-polaroid about-polaroid--right">
              <div class="about-polaroid__frame">
                <img src="{{ section.settings.what_polaroid | image_url: width: 500 }}" alt="" loading="lazy">
                {%- if section.settings.what_caption != blank -%}
                  <span class="about-polaroid__caption">{{ section.settings.what_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Block 3: Mural de marcas — Alt background -->
  <div class="about-brands">
    <div class="container">
      <div class="about-brands__layout">
        {%- if section.settings.brands_polaroid != blank -%}
          <div class="about-brands__polaroid animate-item" style="--i:0">
            <div class="about-polaroid about-polaroid--left">
              <div class="about-polaroid__frame">
                <img src="{{ section.settings.brands_polaroid | image_url: width: 500 }}" alt="" loading="lazy">
                {%- if section.settings.brands_caption != blank -%}
                  <span class="about-polaroid__caption">{{ section.settings.brands_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
        <div class="about-brands__inner">
          <h2 class="about-brands__title animate-item" style="--i:1">
            {{ section.settings.brands_title }}
          </h2>
          <div class="about-brands__text animate-item" style="--i:2">
            {{ section.settings.brands_text }}
          </div>
          {%- if section.settings.brands_button_text != blank -%}
            <a href="{{ section.settings.brands_button_url }}" class="btn btn--primary collage-button about-brands__cta animate-item" style="--i:3">
              {{ section.settings.brands_button_text }}
              {% render 'icon-arrow-right' %}
            </a>
          {%- endif -%}
          {%- if section.settings.sticker_3 != blank -%}
            <div class="about-brands__deco about-sticker">
              <img src="{{ section.settings.sticker_3 | image_url: width: 150 }}" alt="Decoration" loading="lazy">
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <!-- Block 4: Por qué Gifting — Step-card style -->
  <div class="about-why">
    <div class="container">
      <div class="section-header animate-item" style="--i:0">
        <h2 class="section-title">
          {{ section.settings.why_title }}
        </h2>
      </div>
      {%- if section.settings.why_polaroid != blank -%}
        <div class="about-why__polaroid animate-item" style="--i:0">
          <div class="about-polaroid about-polaroid--center">
            <div class="about-polaroid__frame">
              <img src="{{ section.settings.why_polaroid | image_url: width: 500 }}" alt="" loading="lazy">
              {%- if section.settings.why_caption != blank -%}
                <span class="about-polaroid__caption">{{ section.settings.why_caption }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
      <div class="about-why__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'bullet' -%}
            <div class="about-why__card animate-item" style="--i:{{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- if block.settings.bullet_icon != blank -%}
                <div class="about-why__icon">
                  <img src="{{ block.settings.bullet_icon | image_url: width: 80 }}" alt="" loading="lazy">
                </div>
              {%- endif -%}
              <h3 class="about-why__card-title">
                {{ block.settings.bullet_title }}
              </h3>
              <p class="about-why__card-text">{{ block.settings.bullet_text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- Block 5: Fundadoras — Polaroid + content -->
  <div class="about-founders">
    <div class="container">
      <div class="about-founders__grid">
        <div class="about-founders__image animate-item" style="--i:0">
          {%- if section.settings.founders_image != blank -%}
            <div class="about-polaroid about-polaroid--left">
              <div class="about-polaroid__frame">
                <img src="{{ section.settings.founders_image | image_url: width: 800 }}" alt="{{ section.settings.founders_title }}" loading="lazy">
                {%- if section.settings.founders_caption != blank -%}
                  <span class="about-polaroid__caption">{{ section.settings.founders_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
        <div class="about-founders__content">
          <div class="about-founders__badge collage-sticker collage-sticker--handwritten animate-item" style="--i:1">
            {% render 'icon-heart' %}
            <span>Nuestro equipo</span>
          </div>
          <h2 class="about-founders__title animate-item" style="--i:2">
            {{ section.settings.founders_title }}
          </h2>
          <div class="about-founders__text animate-item" style="--i:3">
            {{ section.settings.founders_text }}
          </div>
        </div>
        {%- if section.settings.sticker_4 != blank -%}
          <div class="about-founders__deco about-sticker">
            <img src="{{ section.settings.sticker_4 | image_url: width: 150 }}" alt="Decoration" loading="lazy">
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Block 6: Frase final — Accent background -->
  <div class="about-closing">
    <div class="container">
      <div class="about-closing__inner animate-item" style="--i:0">
        {%- if section.settings.closing_polaroid != blank -%}
          <div class="about-closing__polaroid">
            <div class="about-polaroid about-polaroid--center">
              <div class="about-polaroid__frame">
                <img src="{{ section.settings.closing_polaroid | image_url: width: 400 }}" alt="" loading="lazy">
                {%- if section.settings.closing_caption != blank -%}
                  <span class="about-polaroid__caption">{{ section.settings.closing_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.closing_icon != blank -%}
          <div class="about-closing__icon">
            <img src="{{ section.settings.closing_icon | image_url: width: 80 }}" alt="" loading="lazy">
          </div>
        {%- endif -%}
        <p class="about-closing__text">
          {{ section.settings.closing_text }}
        </p>
      </div>
    </div>
  </div>

</section>

